{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://survivalgarden/contracts/task.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "sourceKey",
    "date",
    "type",
    "cropId",
    "bedId",
    "batchId",
    "checklist",
    "status"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "sourceKey": {
      "$ref": "#/$defs/id"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "cropId": {
      "$ref": "#/$defs/id"
    },
    "bedId": {
      "$ref": "#/$defs/id"
    },
    "batchId": {
      "$ref": "#/$defs/id"
    },
    "checklist": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "status": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    }
  }
}
