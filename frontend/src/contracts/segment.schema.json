{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://survivalgarden/contracts/segment.schema.json",
  "title": "Segment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "segmentId",
    "name",
    "width",
    "height",
    "originReference",
    "beds",
    "paths"
  ],
  "properties": {
    "segmentId": {
      "$ref": "https://survivalgarden/contracts/bed.schema.json#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "width": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "height": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "originReference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "beds": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "https://survivalgarden/contracts/bed.schema.json"
          },
          {
            "type": "object",
            "required": [
              "x",
              "y",
              "width",
              "height"
            ],
            "properties": {
              "x": {
                "type": "number",
                "minimum": 0
              },
              "y": {
                "type": "number",
                "minimum": 0
              },
              "width": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "height": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          }
        ]
      }
    },
    "paths": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/path.schema.json"
      }
    }
  }
}
