{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://survivalgarden/contracts/segment.schema.json",
  "title": "Segment",
  "description": "Segment-local geometry uses a canonical NW-origin coordinate system: x is meters east and y is meters south from the segment's northwest corner.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "segmentId",
    "name",
    "beds",
    "paths"
  ],
  "properties": {
    "segmentId": {
      "$ref": "https://survivalgarden/contracts/bed.schema.json#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "kind": {
      "type": "string",
      "maxLength": 120
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    },
    "widthM": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "lengthM": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "width": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "height": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "originReference": {
      "type": "string",
      "description": "Reference point for segment-local coordinates. Canonical convention is NW corner origin.",
      "minLength": 1,
      "maxLength": 64
    },
    "beds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bedId",
          "gardenId",
          "name",
          "type",
          "createdAt",
          "updatedAt",
          "x",
          "y"
        ],
        "properties": {
          "bedId": {
            "$ref": "https://survivalgarden/contracts/bed.schema.json#/$defs/id"
          },
          "segmentId": {
            "$ref": "https://survivalgarden/contracts/bed.schema.json#/$defs/id"
          },
          "gardenId": {
            "$ref": "https://survivalgarden/contracts/bed.schema.json#/$defs/id"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "type": {
            "$ref": "https://survivalgarden/contracts/bed.schema.json#/$defs/bedType"
          },
          "notes": {
            "type": "string",
            "maxLength": 2000
          },
          "createdAt": {
            "$ref": "https://survivalgarden/contracts/bed.schema.json#/$defs/isoDate"
          },
          "updatedAt": {
            "$ref": "https://survivalgarden/contracts/bed.schema.json#/$defs/isoDate"
          },
          "x": {
            "type": "number",
            "description": "Meters east from parent segment NW corner.",
            "minimum": 0
          },
          "y": {
            "type": "number",
            "description": "Meters south from parent segment NW corner.",
            "minimum": 0
          },
          "widthM": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "lengthM": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "rotationDeg": {
            "type": "number"
          },
          "width": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "height": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "paths": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/path.schema.json"
      }
    }
  }
}
