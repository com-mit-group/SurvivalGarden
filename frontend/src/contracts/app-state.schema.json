{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://survivalgarden/contracts/app-state.schema.json",
  "title": "AppState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "crops",
    "cropPlans",
    "batches",
    "tasks",
    "seedInventoryItems",
    "settings"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "beds": {
      "description": "Deprecated compatibility field. Canonical layout ownership is segments[].beds[].",
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/bed.schema.json"
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/segment.schema.json"
      }
    },
    "species": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/species.schema.json"
      }
    },
    "crops": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/crop.schema.json"
      }
    },
    "cultivars": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/cultivar.schema.json"
      }
    },
    "cropPlans": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/crop-plan.schema.json"
      }
    },
    "batches": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/batch.schema.json"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/task.schema.json"
      }
    },
    "seedInventoryItems": {
      "type": "array",
      "items": {
        "$ref": "https://survivalgarden/contracts/seed-inventory-item.schema.json"
      }
    },
    "settings": {
      "$ref": "https://survivalgarden/contracts/settings.schema.json"
    }
  }
}
